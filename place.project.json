{
    "name": "Nexus-Instance",
    "tree": {
        "$className": "DataModel",
        "Workspace": {
            "$ignoreUnknownInstances": true,
            "$properties": {
                "SignalBehavior": "Deferred"
            }
        },
        "ReplicatedStorage": {
            "$className": "ReplicatedStorage",
            "NexusInstance": {
                "$path": "."
            }
        },
        "TestService": {
            "$className": "TestService",
            "NexusInstance.spec": {
                "$path": "./test"
            },
            "AvantIgnoredPaths": {
                "$className": "StringValue",
                "$properties": {
                    "Value": "[\"StarterPlayer.StarterPlayerScripts.PlayerModule\"]"
                }
            }
        }
    }
}